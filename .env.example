# Create a free key at https://openalex.org/settings/api
OPENALEX_API_KEY=

# Email of the account allowed to open /admin
PAPERLOG_ADMIN_EMAIL=

# App-owned Google/GitHub sign-in (ChatGPT sign-in remains managed by Sites)
# Generate a high-entropy secret and never commit the real value.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://paperlog.net

# Google OAuth callback: https://paperlog.net/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth callback: https://paperlog.net/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

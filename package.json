{
  "name": "paperlog",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && npm run test:unit && npm run test:api",
    "test:unit": "node --test tests/*.test.mjs",
    "test:api": "node scripts/test-api-smoke.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "audit": "npm audit --audit-level=high",
    "backup:restore": "node --no-warnings=ExperimentalWarning scripts/restore-backup.mjs",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "better-auth": "^1.6.23",
    "drizzle-orm": "0.45.2",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@cloudflare/workers-types": "^5.20260714.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "^0.5.27",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "^16.2.10",
    "react-server-dom-webpack": "^19.2.7",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "^8.1.4",
    "wrangler": "^4.110.0"
  },
  "type": "module"
}
